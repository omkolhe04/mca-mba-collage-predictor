# ==========================================================
# SERVER
# ==========================================================
NODE_ENV=development
PORT=3000
APP_NAME=VidyaNITI MCA CET Predictor
APP_BASE_URL=http://localhost:3000

# Only set this if deploying under a subdirectory (e.g. cPanel
# "Setup Node.js App" with Application URL like
# yourdomain.com/some-folder) AND you've noticed the bare
# subdirectory URL 404s while deeper paths work fine. Set it to
# exactly that subdirectory path, e.g.:
# APP_SUBDIRECTORY_BASE_PATH=/collage.predictor
# Leave this commented out / unset for domain-root or subdomain
# deployments, or if the bare subdirectory URL already works.
# APP_SUBDIRECTORY_BASE_PATH=

# ==========================================================
# SUPABASE
# ==========================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=vidyaniti-assets

# Direct Postgres connection string — used ONLY by
# database/run-migrations.js and database/run-seeds.js (schema
# setup tasks). The running app never uses this; it talks to
# Supabase exclusively via supabase-js / SUPABASE_URL above.
# Find it at: Project Settings -> Database -> Connection string
DATABASE_URL=postgres://postgres:[password]@[host]:5432/postgres

# ==========================================================
# SESSION / AUTH
# ==========================================================
# Used to sign the long-lived user identity cookie (no login/signup — invisible session)
USER_SESSION_SECRET=replace-with-a-long-random-string
USER_SESSION_COOKIE_NAME=vn_uid
USER_SESSION_MAX_AGE_DAYS=365

# Used for Admin Panel authentication (JWT)
ADMIN_JWT_SECRET=replace-with-a-different-long-random-string
ADMIN_JWT_EXPIRY=8h

# ==========================================================
# PDF REPORT
# ==========================================================
PDF_BRAND_NAME=VidyaNITI
PDF_WATERMARK_TEXT=VidyaNITI
