<div class="vn-admin-topbar">
  <h1 class="h4 mb-0">Manage Notifications</h1>
  <a href="<%= url('/admin/notifications/new') %>" class="btn btn-vn-primary btn-sm"><%- icon('plus', { class: 'vn-icon-xs me-1' }) %>Add Notification</a>
</div>

<div class="vn-card">
  <% if (!notifications.length) { %>
    <p class="small mb-0 text-center" style="color: var(--vn-ink-muted);">No notifications yet.</p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Title</th>
            <th>Type</th>
            <th>Window</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% notifications.forEach(function (n) { %>
            <tr>
              <td><%= n.title %></td>
              <td><span class="text-capitalize"><%= n.type %></span></td>
              <td class="small">
                <%= n.starts_at ? new Date(n.starts_at).toLocaleDateString('en-IN') : 'Always' %>
                &ndash;
                <%= n.ends_at ? new Date(n.ends_at).toLocaleDateString('en-IN') : 'No end' %>
              </td>
              <td>
                <% if (n.is_active) { %>
                  <span class="vn-badge vn-badge-success">Active</span>
                <% } else { %>
                  <span class="vn-badge vn-badge-danger">Inactive</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="<%= url('/admin/notifications/' + n.id + '/edit') %>" class="btn btn-sm btn-vn-outline">Edit</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
      <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <% for (let p = 1; p <= totalPages; p++) { %>
            <li class="page-item <%= p === page ? 'active' : '' %>">
              <a class="page-link" href="<%= url('/admin/notifications?page=' + p) %>"><%= p %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  <% } %>
</div>
