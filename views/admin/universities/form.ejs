<div class="vn-admin-topbar">
  <h1 class="h4 mb-0">Edit WhatsApp Group</h1>
  <a href="<%= url('/admin/universities') %>" class="btn btn-sm btn-vn-outline">&larr; Back to WhatsApp Groups</a>
</div>

<form action="<%= url('/admin/universities/' + university.id + '/whatsapp/' + examType.id) %>" method="POST">
  <div class="vn-card">
    <div class="row g-3">
      <div class="col-12 col-sm-6">
        <label class="form-label">University</label>
        <input type="text" class="form-control" value="<%= university.name %>" disabled />
      </div>

      <div class="col-12 col-sm-6">
        <label class="form-label">Exam</label>
        <input type="text" class="form-control" value="<%= examType.name %>" disabled />
      </div>

      <div class="col-12">
        <label for="whatsappGroupLink" class="form-label">WhatsApp Group Invite Link</label>
        <input
          type="text"
          class="form-control"
          id="whatsappGroupLink"
          name="whatsappGroupLink"
          value="<%= whatsappGroupLink || '' %>"
          placeholder="https://chat.whatsapp.com/..."
        />
        <div class="form-text">
          Only for students whose Admission University is <strong><%= university.name %></strong>
          and who took <strong><%= examType.name %></strong>. Leave blank to hide the join button
          for this specific combination.
        </div>
      </div>
    </div>
  </div>

  <button type="submit" class="btn btn-vn-primary mt-3">Save Changes</button>
</form>
