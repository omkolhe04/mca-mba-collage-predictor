<div class="vn-admin-topbar">
  <h1 class="h4 mb-0"><%= mode === 'create' ? 'Add Slide' : 'Edit Slide' %></h1>
  <a href="<%= url('/admin/sliders') %>" class="btn btn-sm btn-vn-outline">&larr; Back to Slider</a>
</div>

<form action="<%= url(mode === 'create' ? '/admin/sliders' : '/admin/sliders/' + slider.id) %>" method="POST" enctype="multipart/form-data">
  <div class="vn-card">
    <div class="row g-3">
      <% if (mode === 'edit' && slider.publicUrl) { %>
        <div class="col-12">
          <label class="form-label">Current Image</label>
          <img src="<%= slider.publicUrl %>" alt="<%= slider.title || 'Slide' %>" class="d-block mb-2" style="max-width: 320px; border-radius: var(--vn-radius-sm);" />
        </div>
      <% } %>
      <div class="col-12">
        <label for="image" class="form-label">
          <%= mode === 'create' ? 'Image' : 'Replace Image (optional)' %>
        </label>
        <input type="file" class="form-control" id="image" name="image" accept="image/jpeg,image/png,image/webp,image/gif" <%= mode === 'create' ? 'required' : '' %> />
      </div>
      <div class="col-12">
        <label for="title" class="form-label">Title <span class="text-muted small">(optional)</span></label>
        <input type="text" class="form-control" id="title" name="title" value="<%= slider.title || '' %>" />
      </div>
      <div class="col-12">
        <label for="linkUrl" class="form-label">Link URL <span class="text-muted small">(optional)</span></label>
        <input type="text" class="form-control" id="linkUrl" name="linkUrl" value="<%= slider.link_url || '' %>" placeholder="https://..." />
      </div>
      <div class="col-12 col-sm-6">
        <label for="displayOrder" class="form-label">Display Order</label>
        <input type="number" class="form-control" id="displayOrder" name="displayOrder" value="<%= slider.display_order || 0 %>" />
      </div>
      <div class="col-12 col-sm-6 d-flex align-items-end">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="isActive" name="isActive" <%= (mode === 'create' || slider.is_active) ? 'checked' : '' %> />
          <label class="form-check-label" for="isActive">Active</label>
        </div>
      </div>
    </div>
  </div>

  <button type="submit" class="btn btn-vn-primary mt-3">
    <%= mode === 'create' ? 'Add Slide' : 'Save Changes' %>
  </button>
</form>
