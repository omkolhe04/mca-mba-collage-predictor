<div class="vn-admin-topbar">
  <h1 class="h4 mb-0">Manage Colleges</h1>
  <a href="<%= url('/admin/colleges/new') %>" class="btn btn-vn-primary btn-sm"><%- icon('plus', { class: 'vn-icon-xs me-1' }) %>Add College</a>
</div>

<ul class="nav nav-tabs mb-3">
  <% allExamTypes.forEach(function (et) { %>
    <li class="nav-item">
      <a
        class="nav-link <%= et.id === examType.id ? 'active' : '' %>"
        href="<%= url('/admin/colleges?exam=' + et.code) %>"
      >
        <%= et.name %>
      </a>
    </li>
  <% }) %>
</ul>

<div class="vn-card mb-3">
  <form action="<%= url('/admin/colleges') %>" method="GET" class="d-flex gap-2">
    <input type="hidden" name="exam" value="<%= examType.code %>" />
    <input
      type="text"
      name="search"
      class="form-control"
      placeholder="Search by name or college code..."
      value="<%= search %>"
    />
    <button type="submit" class="btn btn-vn-outline">Search</button>
  </form>
</div>

<div class="vn-card">
  <% if (!colleges.length) { %>
    <p class="small mb-0 text-center" style="color: var(--vn-ink-muted);">
      <%= search ? 'No colleges match your search.' : 'No ' + examType.name + ' colleges yet. Colleges are created automatically when you import cutoff data, or you can add one manually.' %>
    </p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Code</th>
            <th>Name</th>
            <th>University</th>
            <th>Status</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% colleges.forEach(function (college) { %>
            <tr>
              <td><%= college.college_code %></td>
              <td><%= college.name %></td>
              <td><%= college.university_short_name || '—' %></td>
              <td>
                <% if (college.is_active) { %>
                  <span class="vn-badge vn-badge-success">Active</span>
                <% } else { %>
                  <span class="vn-badge vn-badge-danger">Inactive</span>
                <% } %>
              </td>
              <td class="text-end">
                <a href="<%= url('/admin/colleges/' + college.id + '/edit') %>" class="btn btn-sm btn-vn-outline">Edit</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
      <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <% for (let p = 1; p <= totalPages; p++) { %>
            <li class="page-item <%= p === page ? 'active' : '' %>">
              <a class="page-link" href="<%= url('/admin/colleges?exam=' + examType.code + '&page=' + p + (search ? '&search=' + encodeURIComponent(search) : '')) %>"><%= p %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  <% } %>
</div>
