<%
  // Handles both shapes: boolean (loaded fresh from DB via
  // mapColumnsToFormData) and 'on'/undefined (re-rendered after
  // a validation failure, straight from req.body).
  function isChecked(v) { return v === true || v === 'on'; }
%>

<div class="vn-admin-topbar">
  <h1 class="h4 mb-0"><%= mode === 'create' ? 'Add College' : 'Edit College' %></h1>
  <a href="<%= url('/admin/colleges') %>" class="btn btn-sm btn-vn-outline">&larr; Back to Colleges</a>
</div>

<form action="<%= url(mode === 'create' ? '/admin/colleges' : '/admin/colleges/' + college.id) %>" method="POST" novalidate>
  <% if (mode === 'edit') { %>
    <input type="hidden" name="returnPage" value="<%= returnPage %>" />
    <input type="hidden" name="returnSearch" value="<%= returnSearch %>" />
    <input type="hidden" name="returnExam" value="<%= returnExam %>" />
  <% } %>
  <div class="vn-card mb-3">
    <h2 class="h6 mb-3">Basic Details</h2>
    <div class="row g-3">
      <% if (mode === 'create') { %>
        <div class="col-12 col-sm-4">
          <label for="examTypeCode" class="form-label">Exam</label>
          <select class="form-select <%= errors.examTypeCode ? 'is-invalid' : '' %>" id="examTypeCode" name="examTypeCode" required>
            <option value="" disabled selected>Select exam</option>
            <% examTypes.forEach(function (et) { %>
              <option value="<%= et.code %>"><%= et.name %></option>
            <% }) %>
          </select>
          <% if (errors.examTypeCode) { %><div class="invalid-feedback"><%= errors.examTypeCode.msg %></div><% } %>
        </div>
      <% } else { %>
        <div class="col-12 col-sm-4">
          <label class="form-label">Exam</label>
          <input type="text" class="form-control" value="<%= college.examTypeName %>" disabled />
          <div class="form-text">Set once at creation, cannot be changed.</div>
        </div>
      <% } %>
      <div class="col-12 col-sm-4">
        <label for="collegeCode" class="form-label">College Code</label>
        <input type="text" class="form-control <%= errors.collegeCode ? 'is-invalid' : '' %>" id="collegeCode" name="collegeCode" value="<%= college.collegeCode || '' %>" required />
        <% if (errors.collegeCode) { %><div class="invalid-feedback"><%= errors.collegeCode.msg %></div><% } %>
      </div>
      <div class="col-12 col-sm-4">
        <label for="name" class="form-label">College Name</label>
        <input type="text" class="form-control <%= errors.name ? 'is-invalid' : '' %>" id="name" name="name" value="<%= college.name || '' %>" required />
        <% if (errors.name) { %><div class="invalid-feedback"><%= errors.name.msg %></div><% } %>
      </div>

      <div class="col-12 col-sm-6">
        <label for="city" class="form-label">City</label>
        <input type="text" class="form-control" id="city" name="city" value="<%= college.city || '' %>" />
      </div>
      <div class="col-12 col-sm-6">
        <label for="district" class="form-label">District</label>
        <input type="text" class="form-control" id="district" name="district" value="<%= college.district || '' %>" />
      </div>

      <div class="col-12">
        <label for="address" class="form-label">Address</label>
        <textarea class="form-control" id="address" name="address" rows="2"><%= college.address || '' %></textarea>
      </div>

      <div class="col-12 col-sm-4">
        <label for="pincode" class="form-label">Pincode</label>
        <input type="text" class="form-control" id="pincode" name="pincode" value="<%= college.pincode || '' %>" />
      </div>
      <div class="col-12 col-sm-4">
        <label for="universityId" class="form-label">University</label>
        <select class="form-select" id="universityId" name="universityId">
          <option value="">Not set</option>
          <% universities.forEach(function (uni) { %>
            <option value="<%= uni.id %>" <%= college.universityId === uni.id ? 'selected' : '' %>><%= uni.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-12 col-sm-4">
        <label for="establishedYear" class="form-label">Established Year</label>
        <input type="number" class="form-control <%= errors.establishedYear ? 'is-invalid' : '' %>" id="establishedYear" name="establishedYear" value="<%= college.establishedYear || '' %>" />
        <% if (errors.establishedYear) { %><div class="invalid-feedback"><%= errors.establishedYear.msg %></div><% } %>
      </div>
    </div>
  </div>

  <div class="vn-card mb-3">
    <h2 class="h6 mb-3">Links</h2>
    <div class="row g-3">
      <div class="col-12 col-sm-6">
        <label for="websiteUrl" class="form-label">Website URL</label>
        <input type="text" class="form-control <%= errors.websiteUrl ? 'is-invalid' : '' %>" id="websiteUrl" name="websiteUrl" value="<%= college.websiteUrl || '' %>" placeholder="https://..." />
        <% if (errors.websiteUrl) { %><div class="invalid-feedback"><%= errors.websiteUrl.msg %></div><% } %>
      </div>
      <div class="col-12 col-sm-6">
        <label for="googleMapsUrl" class="form-label">Google Maps URL</label>
        <input type="text" class="form-control <%= errors.googleMapsUrl ? 'is-invalid' : '' %>" id="googleMapsUrl" name="googleMapsUrl" value="<%= college.googleMapsUrl || '' %>" placeholder="https://..." />
        <% if (errors.googleMapsUrl) { %><div class="invalid-feedback"><%= errors.googleMapsUrl.msg %></div><% } %>
      </div>
    </div>
  </div>

  <div class="vn-card mb-3">
    <h2 class="h6 mb-3">Accreditation &amp; Facilities</h2>
    <div class="row g-3 align-items-end">
      <div class="col-12 col-sm-4">
        <label for="naacGrade" class="form-label">NAAC Grade</label>
        <input type="text" class="form-control" id="naacGrade" name="naacGrade" value="<%= college.naacGrade || '' %>" placeholder="e.g. A+" />
      </div>
      <div class="col-12 col-sm-4">
        <label for="intakeCapacity" class="form-label">Intake Capacity</label>
        <input type="number" class="form-control <%= errors.intakeCapacity ? 'is-invalid' : '' %>" id="intakeCapacity" name="intakeCapacity" value="<%= college.intakeCapacity || '' %>" />
        <% if (errors.intakeCapacity) { %><div class="invalid-feedback"><%= errors.intakeCapacity.msg %></div><% } %>
      </div>
    </div>
    <div class="row g-2 mt-1">
      <div class="col-6 col-sm-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="nbaAccredited" name="nbaAccredited" <%= isChecked(college.nbaAccredited) ? 'checked' : '' %> />
          <label class="form-check-label" for="nbaAccredited">NBA Accredited</label>
        </div>
      </div>
      <div class="col-6 col-sm-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="aicteApproved" name="aicteApproved" <%= isChecked(college.aicteApproved) ? 'checked' : '' %> />
          <label class="form-check-label" for="aicteApproved">AICTE Approved</label>
        </div>
      </div>
      <div class="col-6 col-sm-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="autonomous" name="autonomous" <%= isChecked(college.autonomous) ? 'checked' : '' %> />
          <label class="form-check-label" for="autonomous">Autonomous</label>
        </div>
      </div>
      <div class="col-6 col-sm-3">
        <div class="form-check">
          <input class="form-check-input" type="checkbox" id="hostelAvailable" name="hostelAvailable" <%= isChecked(college.hostelAvailable) ? 'checked' : '' %> />
          <label class="form-check-label" for="hostelAvailable">Hostel Available</label>
        </div>
      </div>
    </div>
  </div>

  <div class="vn-card mb-3">
    <div class="form-check">
      <input class="form-check-input" type="checkbox" id="isActive" name="isActive" <%= (mode === 'create' || isChecked(college.isActive)) ? 'checked' : '' %> />
      <label class="form-check-label" for="isActive">Active (visible in predictions and search)</label>
    </div>
  </div>

  <button type="submit" class="btn btn-vn-primary">
    <%= mode === 'create' ? 'Add College' : 'Save Changes' %>
  </button>
</form>

<% if (mode === 'edit') { %>
  <!-- ================= Placements ================= -->
  <div class="vn-card mt-4">
    <h2 class="h6 mb-3">Placements</h2>

    <% if (placements && placements.length) { %>
      <div class="table-responsive mb-3">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Year</th>
              <th>Average Package</th>
              <th>Highest Package</th>
              <th>Placed / Eligible</th>
            </tr>
          </thead>
          <tbody>
            <% placements.forEach(function (p) { %>
              <tr>
                <td><%= p.academic_year %></td>
                <td><%= p.average_package_lpa != null ? p.average_package_lpa + ' LPA' : '—' %></td>
                <td><%= p.highest_package_lpa != null ? p.highest_package_lpa + ' LPA' : '—' %></td>
                <td><%= (p.students_placed != null && p.total_eligible != null) ? p.students_placed + ' / ' + p.total_eligible : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <p class="small mb-2" style="color: var(--vn-ink-muted);">
      Add or update a year — submitting the same academic year again updates that row instead of duplicating it.
    </p>
    <form action="<%= url('/admin/colleges/' + college.id + '/placements') %>" method="POST">
      <input type="hidden" name="returnPage" value="<%= returnPage %>" />
      <input type="hidden" name="returnSearch" value="<%= returnSearch %>" />
      <input type="hidden" name="returnExam" value="<%= returnExam %>" />
      <div class="row g-2">
        <div class="col-6 col-sm-3">
          <input type="text" class="form-control form-control-sm" name="academicYear" placeholder="2025-26" required />
        </div>
        <div class="col-6 col-sm-3">
          <input type="number" step="0.01" class="form-control form-control-sm" name="averagePackageLpa" placeholder="Avg LPA" />
        </div>
        <div class="col-6 col-sm-3">
          <input type="number" step="0.01" class="form-control form-control-sm" name="highestPackageLpa" placeholder="Highest LPA" />
        </div>
        <div class="col-3 col-sm-1">
          <input type="number" class="form-control form-control-sm" name="studentsPlaced" placeholder="Placed" />
        </div>
        <div class="col-3 col-sm-1">
          <input type="number" class="form-control form-control-sm" name="totalEligible" placeholder="Eligible" />
        </div>
        <div class="col-6 col-sm-1">
          <button type="submit" class="btn btn-sm btn-vn-outline w-100">Save</button>
        </div>
      </div>
    </form>
  </div>

  <!-- ================= Fees ================= -->
  <div class="vn-card mt-4">
    <h2 class="h6 mb-3">Fees</h2>

    <% if (fees && fees.length) { %>
      <div class="table-responsive mb-3">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Category</th>
              <th>Year</th>
              <th>Annual Fee</th>
              <th>Total Course Fee</th>
            </tr>
          </thead>
          <tbody>
            <% fees.forEach(function (fee) { %>
              <tr>
                <td><%= fee.categoryLabel %></td>
                <td><%= fee.academic_year %></td>
                <td><%= fee.annual_fee != null ? '₹' + Number(fee.annual_fee).toLocaleString('en-IN') : '—' %></td>
                <td><%= fee.total_course_fee != null ? '₹' + Number(fee.total_course_fee).toLocaleString('en-IN') : '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>

    <p class="small mb-2" style="color: var(--vn-ink-muted);">
      Leave category as "All Categories" for the standard fee, or pick a specific category (e.g. TFWS) for a different rate.
    </p>
    <form action="<%= url('/admin/colleges/' + college.id + '/fees') %>" method="POST">
      <input type="hidden" name="returnPage" value="<%= returnPage %>" />
      <input type="hidden" name="returnSearch" value="<%= returnSearch %>" />
      <input type="hidden" name="returnExam" value="<%= returnExam %>" />
      <div class="row g-2">
        <div class="col-6 col-sm-3">
          <select class="form-select form-select-sm" name="categoryId">
            <option value="">All Categories</option>
            <% (categories || []).forEach(function (cat) { %>
              <option value="<%= cat.id %>"><%= cat.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-6 col-sm-3">
          <input type="text" class="form-control form-control-sm" name="academicYear" placeholder="2025-26" required />
        </div>
        <div class="col-6 col-sm-3">
          <input type="number" step="0.01" class="form-control form-control-sm" name="annualFee" placeholder="Annual Fee" required />
        </div>
        <div class="col-6 col-sm-2">
          <input type="number" step="0.01" class="form-control form-control-sm" name="totalCourseFee" placeholder="Total Course Fee" />
        </div>
        <div class="col-12 col-sm-1">
          <button type="submit" class="btn btn-sm btn-vn-outline w-100">Save</button>
        </div>
      </div>
    </form>
  </div>
<% } %>
