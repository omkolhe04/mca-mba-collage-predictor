<div class="vn-admin-topbar">
  <h1 class="h4 mb-0">Manage Exam Types</h1>
  <a href="<%= url('/admin/exam-types/new') %>" class="btn btn-vn-primary btn-sm"><%- icon('plus', { class: 'vn-icon-xs me-1' }) %>Add Exam Type</a>
</div>

<div class="vn-card">
  <p class="small mb-3" style="color: var(--vn-ink-muted);">
    Only <strong>active</strong> exam types are selectable anywhere students or admins actually
    use the site (the prediction form, Manage Colleges, Dashboard, Import Data). Inactive ones
    stay here as placeholders until you're ready to turn them on.
  </p>

  <div class="table-responsive">
    <table class="table align-middle mb-0">
      <thead>
        <tr>
          <th>Code</th>
          <th>Name</th>
          <th>CAP Rounds</th>
          <th>Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% examTypes.forEach(function (examType) { %>
          <tr>
            <td><code><%= examType.code %></code></td>
            <td><%= examType.name %></td>
            <td><%= examType.cap_rounds %></td>
            <td>
              <% if (examType.is_active) { %>
                <span class="vn-badge vn-badge-success">Active</span>
              <% } else { %>
                <span class="vn-badge vn-badge-danger">Inactive</span>
              <% } %>
            </td>
            <td class="text-end">
              <a href="<%= url('/admin/exam-types/' + examType.id + '/edit') %>" class="btn btn-sm btn-vn-outline">Edit</a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
