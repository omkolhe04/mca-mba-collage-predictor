<div class="vn-admin-topbar">
  <h1 class="h4 mb-0">Dashboard</h1>
</div>

<ul class="nav nav-tabs mb-4">
  <% stats.allExamTypes.forEach(function (et) { %>
    <li class="nav-item">
      <a
        class="nav-link <%= et.id === stats.examType.id ? 'active' : '' %>"
        href="<%= url('/admin/dashboard?exam=' + et.code) %>"
      >
        <%= et.name %>
      </a>
    </li>
  <% }) %>
</ul>

<div class="row g-3 mb-4">
  <div class="col-12 col-sm-4">
    <div class="vn-stat-card">
      <p class="small mb-1" style="color: var(--vn-ink-muted);">Total Colleges</p>
      <div class="vn-stat-value"><%= stats.totalColleges %></div>
    </div>
  </div>
  <div class="col-12 col-sm-4">
    <div class="vn-stat-card">
      <p class="small mb-1" style="color: var(--vn-ink-muted);">Total Users <span class="text-muted">(all exams)</span></p>
      <div class="vn-stat-value"><%= stats.totalUsers %></div>
    </div>
  </div>
  <div class="col-12 col-sm-4">
    <div class="vn-stat-card">
      <p class="small mb-1" style="color: var(--vn-ink-muted);">Total Predictions</p>
      <div class="vn-stat-value"><%= stats.totalPredictions %></div>
    </div>
  </div>
</div>

<div class="row g-3 mb-4">
  <div class="col-12 col-lg-7">
    <div class="vn-card">
      <h2 class="h6 mb-3">Predictions — Last 14 Days</h2>
      <canvas id="dailyChart" height="180"></canvas>
    </div>
  </div>
  <div class="col-12 col-lg-5">
    <div class="vn-card">
      <h2 class="h6 mb-3">Predictions by Category</h2>
      <% if (!stats.categoryBreakdown.length) { %>
        <p class="small mb-0" style="color: var(--vn-ink-muted);">No predictions submitted yet.</p>
      <% } else { %>
        <table class="table table-sm mb-0">
          <tbody>
            <% stats.categoryBreakdown.forEach(function (row) { %>
              <tr>
                <td><%= row.category %></td>
                <td class="text-end fw-semibold"><%= row.count %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>

<div class="vn-card">
  <h2 class="h6 mb-3">Recent Predictions</h2>
  <% if (!stats.recentPredictions.length) { %>
    <p class="small mb-0" style="color: var(--vn-ink-muted);">No predictions submitted yet.</p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Mobile</th>
            <th>Percentile</th>
            <th>Submitted</th>
          </tr>
        </thead>
        <tbody>
          <% stats.recentPredictions.forEach(function (p) { %>
            <tr>
              <td><%= p.userName %></td>
              <td><%= p.userMobile %></td>
              <td><%= p.percentile %></td>
              <td><%= new Date(p.createdAt).toLocaleString('en-IN') %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
  (function () {
    const dailyData = <%- JSON.stringify(stats.dailyCounts) %>;
    const ctx = document.getElementById('dailyChart');
    if (!ctx) return;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: dailyData.map((d) => d.date.slice(5)), // MM-DD
        datasets: [
          {
            label: 'Predictions',
            data: dailyData.map((d) => d.count),
            backgroundColor: '#1E5AA8',
            borderRadius: 4,
          },
        ],
      },
      options: {
        plugins: { legend: { display: false } },
        scales: { y: { beginAtZero: true, ticks: { precision: 0 } } },
      },
    });
  })();
</script>
