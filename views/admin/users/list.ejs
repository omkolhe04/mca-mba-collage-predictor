<div class="vn-admin-topbar">
  <h1 class="h4 mb-0">Manage Users</h1>
</div>

<div class="vn-card mb-3">
  <form action="<%= url('/admin/users') %>" method="GET" class="d-flex gap-2">
    <input
      type="text"
      name="search"
      class="form-control"
      placeholder="Search by name, mobile, or email..."
      value="<%= search %>"
    />
    <button type="submit" class="btn btn-vn-outline">Search</button>
  </form>
</div>

<div class="vn-card">
  <% if (!users.length) { %>
    <p class="small mb-0 text-center" style="color: var(--vn-ink-muted);">
      <%= search ? 'No users match your search.' : 'No users yet — users are created automatically when someone submits the prediction form.' %>
    </p>
  <% } else { %>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Mobile</th>
            <th>Email</th>
            <th>Status</th>
            <th>Joined</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function (user) { %>
            <tr>
              <td><%= user.name %></td>
              <td><%= user.mobile %></td>
              <td><%= user.email || '—' %></td>
              <td>
                <% if (user.is_active) { %>
                  <span class="vn-badge vn-badge-success">Active</span>
                <% } else { %>
                  <span class="vn-badge vn-badge-danger">Inactive</span>
                <% } %>
              </td>
              <td><%= new Date(user.created_at).toLocaleDateString('en-IN') %></td>
              <td class="text-end">
                <a href="<%= url('/admin/users/' + user.id) %>" class="btn btn-sm btn-vn-outline">View</a>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (totalPages > 1) { %>
      <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center mb-0">
          <% for (let p = 1; p <= totalPages; p++) { %>
            <li class="page-item <%= p === page ? 'active' : '' %>">
              <a class="page-link" href="<%= url('/admin/users?page=' + p + (search ? '&search=' + encodeURIComponent(search) : '')) %>"><%= p %></a>
            </li>
          <% } %>
        </ul>
      </nav>
    <% } %>
  <% } %>
</div>
