<section id="colleges" class="vn-section vn-mesh-bg">
  <div class="container">
    <div class="text-center mb-5">
      <p class="vn-eyebrow mb-2">What you get</p>
      <h2 class="mb-0">Everything you need to fill your CAP form with confidence</h2>
    </div>

    <div class="row g-4 justify-content-center">
      <div class="col-12 col-sm-6 col-lg-3 vn-reveal">
        <div class="vn-feature-card-glass vn-glass">
          <span class="vn-feature-icon-wrap"><%- icon('check-circle', { class: 'vn-icon-md' }) %></span>
          <h3 class="h6 mb-2">Official CAP Data</h3>
          <p class="small mb-0" style="color: var(--vn-ink-muted);">
            Every prediction is checked against real, official CAP cutoff data — not
            estimates or guesswork.
          </p>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-lg-3 vn-reveal vn-reveal-delay-1">
        <div class="vn-feature-card-glass vn-glass">
          <span class="vn-feature-icon-wrap"><%- icon('award', { class: 'vn-icon-md' }) %></span>
          <h3 class="h6 mb-2">Dream College Analysis</h3>
          <p class="small mb-0" style="color: var(--vn-ink-muted);">
            See exactly how your dream college's chances look, round by round.
          </p>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-lg-3 vn-reveal vn-reveal-delay-2">
        <div class="vn-feature-card-glass vn-glass vn-feature-soon position-relative">
          <span class="vn-badge-coming-soon position-absolute" style="top: 1rem; right: 1rem;">Coming Soon</span>
          <span class="vn-feature-icon-wrap"><%- icon('scale', { class: 'vn-icon-md' }) %></span>
          <h3 class="h6 mb-2">College Comparison</h3>
          <p class="small mb-0" style="color: var(--vn-ink-muted);">
            Compare colleges side by side on fees, placements, and more.
          </p>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-lg-3 vn-reveal vn-reveal-delay-3">
        <div class="vn-feature-card-glass vn-glass">
          <span class="vn-feature-icon-wrap"><%- icon('file-text', { class: 'vn-icon-md' }) %></span>
          <h3 class="h6 mb-2">PDF Report</h3>
          <p class="small mb-0" style="color: var(--vn-ink-muted);">
            Download a polished, shareable report with your full prediction and
            CAP preference list.
          </p>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-lg-3 vn-reveal">
        <div class="vn-feature-card-glass vn-glass">
          <span class="vn-feature-icon-wrap"><%- icon('building-2', { class: 'vn-icon-md' }) %></span>
          <h3 class="h6 mb-2">College Details</h3>
          <p class="small mb-0" style="color: var(--vn-ink-muted);">
            Full profiles for every college — fees, placements, NAAC, hostel, and more.
          </p>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-lg-3 vn-reveal vn-reveal-delay-1">
        <div class="vn-feature-card-glass vn-glass">
          <span class="vn-feature-icon-wrap"><%- icon('layers', { class: 'vn-icon-md' }) %></span>
          <h3 class="h6 mb-2">Round-wise Prediction</h3>
          <p class="small mb-0" style="color: var(--vn-ink-muted);">
            See your chances separately for every CAP round, not just one flat number.
          </p>
        </div>
      </div>

      <div class="col-12 col-sm-6 col-lg-3 vn-reveal vn-reveal-delay-2">
        <div class="vn-feature-card-glass vn-glass vn-feature-soon position-relative">
          <span class="vn-badge-coming-soon position-absolute" style="top: 1rem; right: 1rem;">Coming Soon</span>
          <span class="vn-feature-icon-wrap"><%- icon('sparkles', { class: 'vn-icon-md' }) %></span>
          <h3 class="h6 mb-2">AI Recommendation</h3>
          <p class="small mb-0" style="color: var(--vn-ink-muted);">
            A smarter, learning-based preference order, tailored to your priorities.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
