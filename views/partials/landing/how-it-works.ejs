<section id="how-it-works" class="vn-section" style="background-color: var(--vn-bg-subtle);">
  <div class="container">
    <div class="text-center mb-5">
      <p class="vn-eyebrow mb-2">How it works</p>
      <h2 class="mb-0">From percentile to preference list</h2>
    </div>

    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">
        <div class="vn-timeline">
          <div class="vn-timeline-item vn-reveal">
            <div class="vn-timeline-marker">1</div>
            <div class="vn-timeline-content">
              <h3 class="h5 mb-2">Choose Entrance Exam</h3>
              <p class="mb-0" style="color: var(--vn-ink-muted);">
                Select MCA CET or MBA CET — more exams are on the way.
              </p>
            </div>
          </div>

          <div class="vn-timeline-item vn-reveal vn-reveal-delay-1">
            <div class="vn-timeline-marker">2</div>
            <div class="vn-timeline-content">
              <h3 class="h5 mb-2">Enter Percentile</h3>
              <p class="mb-0" style="color: var(--vn-ink-muted);">
                Add your percentile, category, and any reservations that apply to you —
                TFWS, EWS, PWD, Defence, or Minority.
              </p>
            </div>
          </div>

          <div class="vn-timeline-item vn-reveal vn-reveal-delay-2">
            <div class="vn-timeline-marker">3</div>
            <div class="vn-timeline-content">
              <h3 class="h5 mb-2">Prediction Engine Compares</h3>
              <p class="mb-0" style="color: var(--vn-ink-muted);">
                We check your percentile against official CAP round-wise,
                category-wise cutoff data — not guesswork.
              </p>
            </div>
          </div>

          <div class="vn-timeline-item vn-reveal vn-reveal-delay-3">
            <div class="vn-timeline-marker">4</div>
            <div class="vn-timeline-content">
              <h3 class="h5 mb-2">Get Dream Colleges</h3>
              <p class="mb-0" style="color: var(--vn-ink-muted);">
                See every college you're likely to get, sorted into clear
                chance bands for every CAP round.
              </p>
            </div>
          </div>

          <div class="vn-timeline-item vn-reveal vn-reveal-delay-4">
            <div class="vn-timeline-marker vn-timeline-marker-final">
              <%- icon('download', { class: 'vn-icon-sm' }) %>
            </div>
            <div class="vn-timeline-content">
              <h3 class="h5 mb-2">Download Professional PDF</h3>
              <p class="mb-0" style="color: var(--vn-ink-muted);">
                Get a polished report with your full result and CAP preference
                order, ready to keep or share.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
