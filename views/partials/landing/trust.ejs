<section id="about" class="vn-section" style="background-color: var(--vn-bg-subtle);">
  <div class="container">
    <div class="row align-items-center gy-4">
      <div class="col-12 col-lg-6 vn-reveal">
        <p class="vn-eyebrow mb-2">Why trust this</p>
        <h2 class="mb-3">Built on official CAP cutoff data, not rumors</h2>
        <p class="mb-3" style="color: var(--vn-ink-muted);">
          Every prediction is checked against previous years' CAP round-wise,
          category-wise cutoff data as published for MCA CET and MBA CET
          admissions in Maharashtra — not estimates passed around in
          WhatsApp groups or social media.
        </p>
        <p class="mb-0" style="color: var(--vn-ink-muted);">
          Cutoffs shift a little every year depending on how many students
          apply, so we show you a realistic chance band rather than a false
          promise of certainty.
        </p>
      </div>

      <div class="col-12 col-lg-6">
        <div class="row g-3">
          <div class="col-6 vn-reveal">
            <div class="vn-card text-center h-100 vn-hover-lift">
              <span class="vn-icon-badge mx-auto mb-2">
                <%- icon('check-circle', { class: 'vn-icon-sm' }) %>
              </span>
              <p class="small mb-0 fw-semibold">Official CAP cutoff data</p>
            </div>
          </div>
          <div class="col-6 vn-reveal vn-reveal-delay-1">
            <div class="vn-card text-center h-100 vn-hover-lift">
              <span class="vn-icon-badge mx-auto mb-2">
                <%- icon('layers', { class: 'vn-icon-sm' }) %>
              </span>
              <p class="small mb-0 fw-semibold">Every CAP round covered</p>
            </div>
          </div>
          <div class="col-6 vn-reveal vn-reveal-delay-2">
            <div class="vn-card text-center h-100 vn-hover-lift">
              <span class="vn-icon-badge mx-auto mb-2">
                <%- icon('users', { class: 'vn-icon-sm' }) %>
              </span>
              <p class="small mb-0 fw-semibold">Every reserved category</p>
            </div>
          </div>
          <div class="col-6 vn-reveal vn-reveal-delay-3">
            <div class="vn-card text-center h-100 vn-hover-lift">
              <span class="vn-icon-badge mx-auto mb-2">
                <%- icon('smartphone', { class: 'vn-icon-sm' }) %>
              </span>
              <p class="small mb-0 fw-semibold">Built for mobile</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
