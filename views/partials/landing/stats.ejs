<section class="vn-section py-5">
  <div class="container">
    <div class="row g-3 g-md-4">
      <div class="col-6 col-lg-3 vn-reveal">
        <div class="vn-stat-card-premium">
          <span class="vn-stat-icon-wrap">
            <%- icon('building-2', { class: 'vn-icon-md' }) %>
          </span>
          <div class="vn-stat-number" data-count-to="500" data-count-suffix="+">0</div>
          <p class="vn-stat-label mb-0">Colleges</p>
        </div>
      </div>

      <div class="col-6 col-lg-3 vn-reveal vn-reveal-delay-1">
        <div class="vn-stat-card-premium">
          <span class="vn-stat-icon-wrap">
            <%- icon('file-text', { class: 'vn-icon-md' }) %>
          </span>
          <div class="vn-stat-number" data-count-to="100000" data-count-suffix="+">0</div>
          <p class="vn-stat-label mb-0">CAP Records</p>
        </div>
      </div>

      <div class="col-6 col-lg-3 vn-reveal vn-reveal-delay-2">
        <div class="vn-stat-card-premium">
          <span class="vn-stat-icon-wrap">
            <%- icon('graduation-cap', { class: 'vn-icon-md' }) %>
          </span>
          <div class="vn-stat-number" data-count-to="7" data-count-suffix="+">0</div>
          <p class="vn-stat-label mb-0">Entrance Exams <span class="d-block small">(Future Ready)</span></p>
        </div>
      </div>

      <div class="col-6 col-lg-3 vn-reveal vn-reveal-delay-3">
        <div class="vn-stat-card-premium">
          <span class="vn-stat-icon-wrap">
            <%- icon('check-circle', { class: 'vn-icon-md' }) %>
          </span>
          <div class="vn-stat-number" data-count-to="100" data-count-suffix="%">0</div>
          <p class="vn-stat-label mb-0">Official Data</p>
        </div>
      </div>
    </div>
  </div>
</section>
