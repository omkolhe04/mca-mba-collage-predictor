<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | ' + appName : appName %></title>
  <meta name="description" content="Predict your MCA CET or MBA CET CAP admission college in Maharashtra based on official cutoff data." />
  <link rel="icon" type="image/png" sizes="16x16" href="<%= url('/images/favicon-16.png') %>" />
  <link rel="icon" type="image/png" sizes="32x32" href="<%= url('/images/favicon-32.png') %>" />
  <link rel="icon" type="image/png" sizes="48x48" href="<%= url('/images/favicon-48.png') %>" />
  <link rel="apple-touch-icon" href="<%= url('/images/favicon-48.png') %>" />

  <!-- Bootstrap 5 (kept for grid/components). Bootstrap Icons
       removed — every icon on the public site now uses the
       inline SVG icon() helper instead. -->
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />

  <!-- Typography: Plus Jakarta Sans (premium redesign) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <!-- App styles -->
  <link rel="stylesheet" href="<%= url('/css/style.css') %>" />
  <link rel="stylesheet" href="<%= url('/css/premium.css') %>" />
</head>
<body>
  <%- include('../partials/header') %>

  <main>
    <%- body %>
  </main>

  <%- include('../partials/footer') %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="<%= url('/js/premium-ui.js') %>"></script>
  <script src="<%= url('/js/main.js') %>"></script>
</body>
</html>
