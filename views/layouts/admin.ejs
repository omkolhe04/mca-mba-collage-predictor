<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title + ' | Admin | ' + appName : 'Admin | ' + appName %></title>
  <link rel="icon" type="image/png" sizes="16x16" href="<%= url('/images/favicon-16.png') %>" />
  <link rel="icon" type="image/png" sizes="32x32" href="<%= url('/images/favicon-32.png') %>" />

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="<%= url('/css/style.css') %>" />
  <link rel="stylesheet" href="<%= url('/css/admin.css') %>" />
</head>
<body>
  <% if (typeof currentAdmin !== 'undefined' && currentAdmin) { %>
    <div class="vn-admin-shell">
      <aside class="vn-admin-sidebar">
        <div class="vn-admin-brand">
          <%- include('../partials/brand-lockup', { variant: 'admin' }) %>
        </div>
        <ul class="vn-admin-nav">
          <li><a href="<%= url('/admin/dashboard') %>" class="<%= currentPath.startsWith('/admin/dashboard') ? 'active' : '' %>"><%- icon('layout-dashboard', { class: 'vn-icon-xs me-2' }) %>Dashboard</a></li>
          <li><a href="<%= url('/admin/exam-types') %>" class="<%= currentPath.startsWith('/admin/exam-types') ? 'active' : '' %>"><%- icon('graduation-cap', { class: 'vn-icon-xs me-2' }) %>Exam Types</a></li>
          <li><a href="<%= url('/admin/colleges') %>" class="<%= currentPath.startsWith('/admin/colleges') ? 'active' : '' %>"><%- icon('building-2', { class: 'vn-icon-xs me-2' }) %>Colleges</a></li>
          <li><a href="<%= url('/admin/import') %>" class="<%= currentPath.startsWith('/admin/import') ? 'active' : '' %>"><%- icon('upload', { class: 'vn-icon-xs me-2' }) %>Import Data</a></li>
          <li><a href="<%= url('/admin/users') %>" class="<%= currentPath.startsWith('/admin/users') ? 'active' : '' %>"><%- icon('users', { class: 'vn-icon-xs me-2' }) %>Users</a></li>
          <li><a href="<%= url('/admin/notifications') %>" class="<%= currentPath.startsWith('/admin/notifications') ? 'active' : '' %>"><%- icon('megaphone', { class: 'vn-icon-xs me-2' }) %>Notifications</a></li>
          <li><a href="<%= url('/admin/sliders') %>" class="<%= currentPath.startsWith('/admin/sliders') ? 'active' : '' %>"><%- icon('image', { class: 'vn-icon-xs me-2' }) %>Slider</a></li>
          <li><a href="<%= url('/admin/universities') %>" class="<%= currentPath.startsWith('/admin/universities') ? 'active' : '' %>"><%- whatsappIcon({ class: 'vn-icon-xs me-2' }) %>WhatsApp Groups</a></li>
        </ul>
        <form action="<%= url('/admin/logout') %>" method="POST" class="mt-3">
          <button type="submit" class="btn btn-sm btn-vn-outline w-100 d-inline-flex align-items-center justify-content-center gap-1" style="border-color: rgba(255,255,255,0.3); color: rgba(255,255,255,0.85);">
            <%- icon('log-out', { class: 'vn-icon-xs' }) %> Log out
          </button>
        </form>
      </aside>
      <main class="vn-admin-content">
        <%- include('../partials/toast-success') %>
        <%- body %>
      </main>
    </div>
  <% } else { %>
    <main>
      <%- body %>
    </main>
  <% } %>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  
  <!-- Vercel Web Analytics -->
  <script>
    window.va = window.va || function () { (window.vaq = window.vaq || []).push(arguments); };
  </script>
  <script defer src="/_vercel/insights/script.js"></script>
</body>
</html>
