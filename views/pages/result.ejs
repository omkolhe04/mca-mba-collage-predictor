<section class="vn-section pb-3">
  <div class="container text-center">
    <p class="vn-eyebrow mb-2">Your Result</p>
    <h1 class="h3 mb-4"><%= examName %> Prediction Result</h1>
  </div>
</section>

<% if (!snapshot || snapshot.totalCollegesEvaluated === 0) { %>

  <!-- ================= Empty state ================= -->
  <section class="vn-section pt-0">
    <div class="container vn-container-narrow">
      <div class="vn-card vn-empty-state">
        <span class="vn-empty-state-icon">
          <%- icon('calendar', { class: 'vn-icon-lg' }) %>
        </span>
        <h2 class="vn-empty-state-title">Results aren't ready yet</h2>
        <p class="vn-empty-state-desc mb-3">
          <%= (snapshot && snapshot.note) || 'Official CAP cutoff data has not been loaded yet.' %>
          Your details are saved — check back once cutoff data is available and results will
          appear here automatically.
        </p>
        <a href="<%= url('/') %>" class="btn btn-vn-outline d-inline-flex align-items-center gap-2">
          <%- icon('house', { class: 'vn-icon-sm' }) %>
          Back to Home
        </a>
      </div>
    </div>
  </section>

<% } else { %>

  <!-- ================= Summary dashboard ================= -->
  <section class="vn-section pt-0 pb-4">
    <div class="container">
      <div class="row g-3">
        <div class="col-6 col-lg-3">
          <div class="vn-stat-card-premium">
            <span class="vn-stat-icon-wrap"><%- icon('target', { class: 'vn-icon-md' }) %></span>
            <div class="vn-stat-number" style="font-size: 1.75rem;"><%= prediction.percentile %></div>
            <p class="vn-stat-label mb-0">Your Percentile</p>
          </div>
        </div>
        <div class="col-6 col-lg-3">
          <div class="vn-stat-card-premium">
            <span class="vn-stat-icon-wrap"><%- icon('building-2', { class: 'vn-icon-md' }) %></span>
            <div class="vn-stat-number" style="font-size: 1.75rem;"><%= snapshot.totalCollegesEvaluated %></div>
            <p class="vn-stat-label mb-0">Colleges Evaluated</p>
          </div>
        </div>
        <% if (admissionUniversity && admissionUniversity.whatsapp_group_link) { %>
          <div class="col-6 col-lg-3">
            <a
              href="<%= admissionUniversity.whatsapp_group_link %>"
              target="_blank"
              rel="noopener noreferrer"
              class="vn-stat-card-premium d-flex flex-column align-items-center justify-content-center h-100 text-decoration-none"
            >
              <span class="vn-stat-icon-wrap" style="background-color: transparent;">
                <%- whatsappIcon({ class: 'vn-icon-lg' }) %>
              </span>
              <p class="mb-0 fw-semibold small text-center" style="color: var(--vn-ink);">
                Join <%= admissionUniversity.short_name || admissionUniversity.name %> Admission Support Group
              </p>
            </a>
          </div>
        <% } else { %>
          <div class="col-6 col-lg-3">
            <div class="vn-stat-card-premium">
              <span class="vn-stat-icon-wrap"><%- icon('shield', { class: 'vn-icon-md' }) %></span>
              <div class="vn-stat-number" style="font-size: 1.75rem;"><%= snapshot.eligibleCategories.length %></div>
              <p class="vn-stat-label mb-0">Eligible Categories</p>
            </div>
          </div>
        <% } %>
        <div class="col-6 col-lg-3">
          <div class="vn-stat-card-premium">
            <span class="vn-stat-icon-wrap"><%- icon('calendar', { class: 'vn-icon-md' }) %></span>
            <div class="vn-stat-number" style="font-size: 1.75rem;"><%= snapshot.examYear %></div>
            <p class="vn-stat-label mb-0">CAP Cutoff Year Used</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= Round tabs ================= -->
  <section class="vn-section pt-0">
    <div class="container">
      <ul class="nav vn-round-tabs" id="roundTabs" role="tablist">
        <% CAP_ROUNDS.forEach(function (roundCode, idx) { %>
          <li class="nav-item" role="presentation">
            <button
              class="nav-link <%= idx === 0 ? 'active' : '' %>"
              id="tab-<%= roundCode %>"
              data-bs-toggle="tab"
              data-bs-target="#pane-<%= roundCode %>"
              type="button"
              role="tab"
              aria-controls="pane-<%= roundCode %>"
              aria-selected="<%= idx === 0 ? 'true' : 'false' %>"
            >
              CAP Round <%= idx + 1 %>
            </button>
          </li>
        <% }) %>
      </ul>

      <div class="tab-content pt-4" id="roundTabsContent">
        <% CAP_ROUNDS.forEach(function (roundCode, idx) { %>
          <div
            class="tab-pane fade <%= idx === 0 ? 'show active' : '' %>"
            id="pane-<%= roundCode %>"
            role="tabpanel"
            aria-labelledby="tab-<%= roundCode %>"
          >
            <%- include('../partials/result/round-panel', {
              roundCode,
              roundData: snapshot.rounds[roundCode],
              dreamCollege: snapshot.dreamCollege,
              collegeDetails,
              CHANCE_BUCKET_META
            }) %>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- ================= Recommended preference order ================= -->
  <section class="vn-section" style="background-color: var(--vn-bg-subtle);">
    <div class="container">
      <div class="text-center mb-4">
        <p class="vn-eyebrow mb-2">Use This For Your CAP Option Form</p>
        <h2 class="h4 mb-0">Recommended Preference Order</h2>
      </div>
      <%- include('../partials/result/preference-order', {
        recommendedPreferenceOrder: snapshot.recommendedPreferenceOrder,
        CHANCE_BUCKET_META
      }) %>
    </div>
  </section>

  <!-- ================= PDF download ================= -->
  <section class="vn-section">
    <div class="container text-center">
      <div class="d-flex flex-wrap justify-content-center gap-3">
        <a
          href="<%= url('/predict/' + prediction.id + '/pdf') %>"
          id="pdfDownloadBtn"
          class="btn btn-vn-primary btn-lg vn-magnetic vn-ripple-container d-inline-flex align-items-center gap-2"
        >
          <span id="pdfDownloadLabel">Download PDF Report</span>
          <%- icon('download', { class: 'vn-icon-sm' }) %>
        </a>
        <a
          href="<%= url('/predict?new=true') %>"
          class="btn btn-vn-outline btn-lg vn-magnetic d-inline-flex align-items-center gap-2"
        >
          <%- icon('sparkles', { class: 'vn-icon-sm' }) %>
          New Prediction
        </a>
      </div>
      <p class="small mt-2 mb-0" style="color: var(--vn-ink-muted);">
        A printable copy of this result, including your CAP preference order.
      </p>
    </div>
  </section>

  <script>
    // Optimistic loading-state text on the PDF button. The
    // actual download is a normal browser file download (no
    // fetch/XHR involved, so there's no real progress event to
    // hook into) — this just cycles reassuring status text for
    // a few seconds after the click, then reverts, independent
    // of when the browser actually finishes saving the file.
    (function () {
      const btn = document.getElementById('pdfDownloadBtn');
      const label = document.getElementById('pdfDownloadLabel');
      if (!btn || !label) return;

      const messages = ['Preparing Report…', 'Generating PDF…', 'Almost Ready…'];
      let cancelled = false;

      btn.addEventListener('click', () => {
        cancelled = false;
        let i = 0;
        label.textContent = messages[0];
        const interval = setInterval(() => {
          i += 1;
          if (cancelled || i >= messages.length) {
            clearInterval(interval);
            setTimeout(() => {
              if (!cancelled) label.textContent = 'Download PDF Report';
            }, 900);
            return;
          }
          label.textContent = messages[i];
        }, 900);
      });
    })();
  </script>

<% } %>
